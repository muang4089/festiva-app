<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:background="@drawable/ad_banner_round"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:paddingTop="3.5dp"
    android:paddingBottom="3.5dp">
    <ImageView
      android:id="@+id/ad_app_icon"
      android:layout_width="54.5dp"
      android:layout_height="54.5dp"
      android:background="@drawable/ad_banner_icon"
      android:clipToOutline="true" />
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_marginLeft="6dp"
      android:layout_height="wrap_content"
      android:orientation="vertical">
        <TextView
          android:id="@+id/ad_headline"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:maxLines="1"
          android:textColor="#1f1f1f"
          android:ellipsize="end"
          android:textSize="15.5sp"
          android:fontFamily="@font/pretendard_bold" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1.4dp"
            android:orientation="horizontal">
            <Button
              android:layout_width="wrap_content"
              android:layout_height="16.5dp"
              android:background="@drawable/ad_label_banner"
              android:fontFamily="@font/pretendard_medium"
              android:gravity="center"
              android:paddingLeft="3.5dp"
              android:paddingRight="3.5dp"
              android:stateListAnimator="@null"
              android:text="AD"
              android:textColor="#4d4d4d"
              android:textSize="11sp" />
            <TextView
              android:id="@+id/ad_body"
              android:layout_marginLeft="4dp"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:ellipsize="end"
              android:fontFamily="@font/pretendard_medium"
              android:textColor="#4d4d4d"
              android:maxLines="1"
              android:textSize="13.4sp" />
        </LinearLayout>
        <Button
          android:id="@+id/ad_call_to_action"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="right"
          android:layout_marginTop="2.4dp"
          android:layout_marginRight="2.4dp"
          android:stateListAnimator="@null"
          android:background="@android:color/transparent"
          android:fontFamily="@font/pretendard_regular"
          android:textColor="#494949"
          android:textSize="12.7sp" />
    </LinearLayout>
  </LinearLayout>
</com.google.android.gms.ads.nativead.NativeAdView>